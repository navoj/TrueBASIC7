option nolet
dim t(5,5)
mat t =0
t(1,1)=2800
t(1,2)=-2800
t(2,1)=-2800
t(2,2)=5600
t(2,3)=-2800
t(3,2)=-2800
t(3,3)=5600
t(3,4)=-2800
t(4,3)=-2800
t(4,4)=5600
t(5,5)=1
mat print t
dim d(1)
mat redim d(5)
d(1)=1125
d(2)=2250
d(3)=2250
d(4)=2250+2800*40
d(5)=40
mat print d
dim x(5)
mat print x
dim tt(5,5)
mat tt=inv(t)
mat print tt
mat x=tt*d
mat print x
end


