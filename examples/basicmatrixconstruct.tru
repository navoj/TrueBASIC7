e(1,2)=2
e(2,1)=3
e(2,2)=4
dim d(1,2)
print " given = matrix b,c "
print " b= "
mat print b
print " c= "
mat print c
!*************************************
! multiplication two matrices
! b(1,2)*c(2,2) => d(1,2)
! (1,2)*(2,2) contract to (1,2)
!*************************************
! 1e) (1,2)*(2,2) = (1,2)
!*************************************
