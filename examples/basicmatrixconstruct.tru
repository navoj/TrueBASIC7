mat print d
dim cmat(1,1)
!*************************************
! multiplicatication two matrices
! d(1,2)*a(2,1) = > number 
!*************************************
! 2e) (1,2)*(2,1) = (1,1) = number
!*************************************
print " given = matrix a "
