#!/usr/bin/env raku

=begin pod
=head1 Graphics Module

Translation of graphic.pas from Decimal BASIC to Raku
Contains graphics and plotting functionality for the True BASIC interpreter.
Provides coordinate transformations, plotting commands, and drawing primitives.

Author: Translated from Pascal by AI Assistant
Based on work by SHIRAISHI Kazuo
=end pod

use v6.d;
use Statement;
use Expression;
use Variable;

=begin pod
=head2 Graphics System Core
=end pod

# Graphics context and state
class GraphicsContext is export {
    has $.window-width is rw = 640;
    has $.window-height is rw = 480;
    has $.viewport-left is rw = 0.0;
    has $.viewport-right is rw = 1.0;
    has $.viewport-bottom is rw = 0.0;
    has $.viewport-top is rw = 1.0;
    has $.world-left is rw = 0.0;
    has $.world-right is rw = 1.0;
    has $.world-bottom is rw = 0.0;
    has $.world-top is rw = 1.0;
    
    # Current graphics state
    has $.current-x is rw = 0.0;
    has $.current-y is rw = 0.0;
    has $.beam-mode is rw = "ON";
    has $.point-style is rw = 1;
    has $.point-color is rw = 1;
    has $.text-color is rw = 1;
    has $.line-style is rw = 1;
    has $.line-color is rw = 1;
    
    # SVG graphics elements
    has @.svg-elements;
    has Bool $.graphics-active is rw = False;
    has Str $.output-file is rw = "plot.svg";
    
    method add-element($element) {
        @.svg-elements.push($element);
    }
    
    method clear-elements() {
        @.svg-elements = ();
    }
    
    method world-to-pixel-x($world-x) returns Num {
        my $viewport-width = $.viewport-right - $.viewport-left;
        my $world-width = $.world-right - $.world-left;
        
        my $normalized = ($world-x.Num - $.world-left) / $world-width;
        return $.viewport-left * $.window-width + $normalized * $viewport-width * $.window-width;
    }
    
    method world-to-pixel-y($world-y) returns Num {
        my $viewport-height = $.viewport-top - $.viewport-bottom;
        my $world-height = $.world-top - $.world-bottom;
        
        my $normalized = ($world-y.Num - $.world-bottom) / $world-height;
        # Flip Y coordinate for SVG coordinates
        return $.window-height - ($.viewport-bottom * $.window-height + $normalized * $viewport-height * $.window-height);
    }
    
    method get-color(Int $color-index) returns Str {
        given $color-index {
            when 0 { return "white"; }
            when 1 { return "black"; }
            when 2 { return "red"; }
            when 3 { return "green"; }
            when 4 { return "blue"; }
            when 5 { return "yellow"; }
            when 6 { return "magenta"; }
            when 7 { return "cyan"; }
            when 8 { return "gray"; }
            default { return "black"; }
        }
    }
    
    method to-svg() returns Str {
        my $svg = qq:to/END/;
        <?xml version="1.0" encoding="UTF-8"?>
        <svg width="{$.window-width}" height="{$.window-height}" xmlns="http://www.w3.org/2000/svg">
        <rect width="100%" height="100%" fill="white"/>
        {@.svg-elements.join("\n")}
        </svg>
        END
        
        return $svg;
    }
    
    method save-to-file(Str $filename = $.output-file) {
        spurt $filename, self.to-svg();
    }
}

my $graphics-context = GraphicsContext.new;

=begin pod
=head2 Coordinate Transformation Functions
=end pod

# Convert world coordinates to pixel coordinates
sub world-to-pixel-x($world-x) returns Int is export {
    return $graphics-context.world-to-pixel-x($world-x).Int;
}

sub world-to-pixel-y($world-y) returns Int is export {
    return $graphics-context.world-to-pixel-y($world-y).Int;
}

# Convert pixel coordinates to world coordinates
sub pixel-to-world-x(Int $pixel-x) returns Num is export {
    my $viewport-width = $graphics-context.viewport-right - $graphics-context.viewport-left;
    my $world-width = $graphics-context.world-right - $graphics-context.world-left;
    
    my $normalized = ($pixel-x - $graphics-context.viewport-left * $graphics-context.window-width) / 
                     ($viewport-width * $graphics-context.window-width);
    
    return $graphics-context.world-left + $normalized * $world-width;
}

sub pixel-to-world-y(Int $pixel-y) returns Num is export {
    my $viewport-height = $graphics-context.viewport-top - $graphics-context.viewport-bottom;
    my $world-height = $graphics-context.world-top - $graphics-context.world-bottom;
    
    # Flip Y coordinate for screen coordinates
    my $flipped-y = $graphics-context.window-height - $pixel-y;
    my $normalized = ($flipped-y - $graphics-context.viewport-bottom * $graphics-context.window-height) / 
                     ($viewport-height * $graphics-context.window-height);
    
    return $graphics-context.world-bottom + $normalized * $world-height;
}

=begin pod
=head2 SVG Graphics Primitives
=end pod

# Point plotting
sub plot-point($x, $y) is export {
    if !$graphics-context.graphics-active {
        return;
    }
    
    my $pixel-x = $graphics-context.world-to-pixel-x($x);
    my $pixel-y = $graphics-context.world-to-pixel-y($y);
    my $color = $graphics-context.get-color($graphics-context.point-color);
    
    given $graphics-context.point-style {
        when 1 { # Circle
            $graphics-context.add-element(qq[<circle cx="{$pixel-x}" cy="{$pixel-y}" r="2" fill="{$color}" />]);
        }
        when 2 { # Square
            $graphics-context.add-element(qq[<rect x="{$pixel-x - 2}" y="{$pixel-y - 2}" width="4" height="4" fill="{$color}" />]);
        }
        when 3 { # Plus sign
            $graphics-context.add-element(qq[<g stroke="{$color}" stroke-width="1">]);
            $graphics-context.add-element(qq[<line x1="{$pixel-x - 3}" y1="{$pixel-y}" x2="{$pixel-x + 3}" y2="{$pixel-y}"/>]);
            $graphics-context.add-element(qq[<line x1="{$pixel-x}" y1="{$pixel-y - 3}" x2="{$pixel-x}" y2="{$pixel-y + 3}"/>]);
            $graphics-context.add-element(qq[</g>]);
        }
        default { # Default to circle
            $graphics-context.add-element(qq[<circle cx="{$pixel-x}" cy="{$pixel-y}" r="2" fill="{$color}" />]);
        }
    }
    
    # Update current position
    $graphics-context.current-x = $x;
    $graphics-context.current-y = $y;
}

# Line drawing
sub draw-line($x1, $y1, $x2, $y2) is export {
    if !$graphics-context.graphics-active {
        return;
    }
    
    my $pixel-x1 = $graphics-context.world-to-pixel-x($x1);
    my $pixel-y1 = $graphics-context.world-to-pixel-y($y1);
    my $pixel-x2 = $graphics-context.world-to-pixel-x($x2);
    my $pixel-y2 = $graphics-context.world-to-pixel-y($y2);
    my $color = $graphics-context.get-color($graphics-context.line-color);
    
    # Add line style support
    my $stroke-dasharray = '';
    given $graphics-context.line-style {
        when 1 { $stroke-dasharray = ''; }  # Solid
        when 2 { $stroke-dasharray = ' stroke-dasharray="5,5"'; }  # Dashed
        when 3 { $stroke-dasharray = ' stroke-dasharray="1,3"'; }  # Dotted
        when 4 { $stroke-dasharray = ' stroke-dasharray="5,3,1,3"'; }  # Dash-dot
        default { $stroke-dasharray = ''; }
    }
    
    $graphics-context.add-element(qq[<line x1="{$pixel-x1}" y1="{$pixel-y1}" x2="{$pixel-x2}" y2="{$pixel-y2}" stroke="{$color}" stroke-width="1"{$stroke-dasharray} />]);
    
    # Update current position to end point
    $graphics-context.current-x = $x2;
    $graphics-context.current-y = $y2;
}

# Move current position without drawing
sub move-to(Num $x, Num $y) is export {
    $graphics-context.current-x = $x;
    $graphics-context.current-y = $y;
}

# Draw to position from current position
sub draw-to(Num $x, Num $y) is export {
    if $graphics-context.beam-mode eq "ON" {
        draw-line($graphics-context.current-x, $graphics-context.current-y, $x, $y);
    }
    move-to($x, $y);
}

# Draw polygon outline
sub draw-polygon(@points) is export {
    if !$graphics-context.graphics-active || @points.elems < 3 {
        return;
    }
    
    my @pixel-points = @points.map({
        ($graphics-context.world-to-pixel-x($_[0]), $graphics-context.world-to-pixel-y($_[1]))
    });
    
    my $points-str = @pixel-points.map({ "{$_[0]},{$_[1]}" }).join(" ");
    my $color = $graphics-context.get-color($graphics-context.line-color);
    
    $graphics-context.add-element(qq[<polygon points="{$points-str}" fill="none" stroke="{$color}" stroke-width="1" />]);
}

=begin pod
=head2 Graphics Commands Implementation
=end pod

# SET WINDOW command
class SetWindowCommand does TBStatement is export {
    has Principal $.x1;
    has Principal $.x2;
    has Principal $.y1;
    has Principal $.y2;
    
    method exec() {
        my $left = $.x1.eval().value.Num;
        my $right = $.x2.eval().value.Num;
        my $bottom = $.y1.eval().value.Num;
        my $top = $.y2.eval().value.Num;
        
        if $left == $right || $bottom == $top {
            die "SET WINDOW: Invalid window dimensions (zero width or height)";
        }
        
        $graphics-context.world-left = $left;
        $graphics-context.world-right = $right;
        $graphics-context.world-bottom = $bottom;
        $graphics-context.world-top = $top;
    }
}

# SET VIEWPORT command
class SetViewportCommand does TBStatement is export {
    has Principal $.x1;
    has Principal $.x2;
    has Principal $.y1;
    has Principal $.y2;
    
    method exec() {
        my $left = $.x1.eval().value.Num;
        my $right = $.x2.eval().value.Num;
        my $bottom = $.y1.eval().value.Num;
        my $top = $.y2.eval().value.Num;
        
        # Validate viewport coordinates (must be between 0 and 1)
        if $left < 0 || $right > 1 || $bottom < 0 || $top > 1 ||
           $left >= $right || $bottom >= $top {
            die "SET VIEWPORT: Invalid viewport coordinates (must be 0-1 and left<right, bottom<top)";
        }
        
        $graphics-context.viewport-left = $left;
        $graphics-context.viewport-right = $right;
        $graphics-context.viewport-bottom = $bottom;
        $graphics-context.viewport-top = $top;
    }
}

# PLOT command
class PlotCommand does TBStatement is export {
    has Principal $.x;
    has Principal $.y;
    
    method exec() {
        my $x = $.x.eval().value.Num;
        my $y = $.y.eval().value.Num;
        
        plot-point($x, $y);
        move-to($x, $y);
    }
}

# PLOT LINES command
class PlotLinesCommand does TBStatement is export {
    has Principal @.coordinates;
    
    method exec() {
        if @.coordinates.elems %% 2 == 1 {
            die "PLOT LINES: Coordinates must be in pairs";
        }
        
        my $first = True;
        for @.coordinates.rotor(2) -> [$x-expr, $y-expr] {
            my $x = $x-expr.eval().value.Num;
            my $y = $y-expr.eval().value.Num;
            
            if $first {
                move-to($x, $y);
                $first = False;
            } else {
                draw-to($x, $y);
            }
        }
    }
}

# PLOT AREA command
class PlotAreaCommand does TBStatement is export {
    has Principal @.coordinates;
    
    method exec() {
        if @.coordinates.elems %% 2 == 1 {
            die "PLOT AREA: Coordinates must be in pairs";
        }
        
        my @points;
        for @.coordinates.rotor(2) -> [$x-expr, $y-expr] {
            my $x = $x-expr.eval().value.Num;
            my $y = $y-expr.eval().value.Num;
            @points.push(($x, $y));
        }
        
        # Draw filled polygon
        # Implementation depends on graphics library
        if @points.elems >= 3 {
            # Close the polygon by drawing back to first point
            draw-filled-polygon(@points);
        }
    }
}

# BEAM command
class BeamCommand does TBStatement is export {
    has Str $.mode;
    
    method exec() {
        $graphics-context.beam-mode = $.mode.uc;
    }
}

# CLEAR command
class ClearCommand does TBStatement is export {
    method exec() {
        clear-graphics();
    }
}

=begin pod
=head2 Graphics State Management
=end pod

# Set point style
sub set-point-style(Int $style) is export {
    $graphics-context.point-style = $style;
}

sub get-point-style() returns Int is export {
    return $graphics-context.point-style;
}

# Set point color
sub set-point-color(Int $color) is export {
    $graphics-context.point-color = $color;
}

sub get-point-color() returns Int is export {
    return $graphics-context.point-color;
}

# Set text color
sub set-text-color(Int $color) is export {
    $graphics-context.text-color = $color;
}

sub get-text-color() returns Int is export {
    return $graphics-context.text-color;
}

# Set beam mode
sub set-beam-mode(Str $mode) returns Bool is export {
    my $upper-mode = $mode.uc;
    if $upper-mode eq "ON" || $upper-mode eq "OFF" {
        $graphics-context.beam-mode = $upper-mode;
        return True;
    }
    return False;
}

sub ask-beam-mode() returns Str is export {
    return $graphics-context.beam-mode;
}

=begin pod
=head2 Advanced Graphics Functions
=end pod

# Draw filled polygon
sub draw-filled-polygon(@points) is export {
    if !$graphics-context.graphics-active || @points.elems < 3 {
        return;
    }
    
    my $polygon-op = PolygonOperation.new(
        points => @points,
        color => $graphics-context.line-color,
        filled => True
    );
    
    $graphics-context.add-operation($polygon-op);
    
    # Execute immediately if we have a cairo context
    if $graphics-context.cairo-context {
        $polygon-op.execute($graphics-context.cairo-context);
        refresh-canvas();
    }
}

# Draw text at position
sub plot-text(Str $text, Num $x, Num $y) is export {
    if !$graphics-context.graphics-active {
        return;
    }
    
    my $text-op = TextOperation.new(
        text => $text,
        x => $x,
        y => $y,
        color => $graphics-context.text-color,
        font => "Arial",
        size => 12
    );
    
    $graphics-context.add-operation($text-op);
    
    # Execute immediately if we have a cairo context
    if $graphics-context.cairo-context {
        $text-op.execute($graphics-context.cairo-context);
        refresh-canvas();
    }
    
    move-to($x, $y);
}

# Get current position
sub ask-current-position() returns Array is export {
    return [$graphics-context.current-x, $graphics-context.current-y];
}

=begin pod
=head2 Matrix Plotting Functions
=end pod

# MATPLOT command for plotting arrays
class MatplotCommand does TBStatement is export {
    has Variable $.matrix;
    
    method exec() {
        # Get matrix data
        my $matrix-value = $.matrix.get-value();
        
        # Implement matrix plotting based on array type
        # This would depend on the specific matrix format
        
        # For now, basic implementation for 2D arrays
        if $matrix-value ~~ Array {
            # Plot points from array data
            # Implementation would vary based on array structure
        }
    }
}

# Graphics initialization
sub init-graphics() is export {
    $graphics-context.graphics-active = True;
    $graphics-context.clear-elements();
    
    # SVG-based graphics - no external dependencies needed
    say "Graphics system initialized (SVG output)" if $*debug;
    
    return True;
}

# Graphics cleanup
sub cleanup-graphics() is export {
    $graphics-context.graphics-active = False;
    
    # Save graphics to file if there are elements to save
    if $graphics-context.svg-elements.elems > 0 {
        $graphics-context.save-to-file();
        say "Graphics saved to {$graphics-context.output-file}";
    }
    
    $graphics-context.clear-elements();
}

# Clear the graphics canvas
sub clear-graphics() is export {
    if $graphics-context.graphics-active {
        $graphics-context.clear-elements();
        # Add white background
        $graphics-context.add-element(qq[<rect width="100%" height="100%" fill="white"/>]);
    }
}

# Export graphics to file
sub export-graphics(Str $filename, Str $format = 'svg') is export {
    if !$graphics-context.graphics-active {
        die "Graphics not active - cannot export";
    }
    
    if $format.lc eq 'svg' {
        $graphics-context.save-to-file($filename);
        return True;
    } else {
        warn "Only SVG format is currently supported";
        return False;
    }
}

=begin pod
=head2 Graphics Query Functions
=end pod

# ASK STATUS implementation for graphics
class AskStatusCommand does TBStatement is export {
    has Variable $.status-var;
    
    method exec() {
        my $status = $graphics-context.graphics-active ?? "GRAPHICS" !! "TEXT";
        $.status-var.set-value(TBString.new(value => $status));
    }
}

# ASK WINDOW implementation
class AskWindowCommand does TBStatement is export {
    has Variable $.left-var;
    has Variable $.right-var;
    has Variable $.bottom-var;
    has Variable $.top-var;
    
    method exec() {
        $.left-var.set-value(TBNumber.new(value => $graphics-context.world-left));
        $.right-var.set-value(TBNumber.new(value => $graphics-context.world-right));
        $.bottom-var.set-value(TBNumber.new(value => $graphics-context.world-bottom));
        $.top-var.set-value(TBNumber.new(value => $graphics-context.world-top));
    }
}

# ASK VIEWPORT implementation
class AskViewportCommand does TBStatement is export {
    has Variable $.left-var;
    has Variable $.right-var;
    has Variable $.bottom-var;
    has Variable $.top-var;
    
    method exec() {
        $.left-var.set-value(TBNumber.new(value => $graphics-context.viewport-left));
        $.right-var.set-value(TBNumber.new(value => $graphics-context.viewport-right));
        $.bottom-var.set-value(TBNumber.new(value => $graphics-context.viewport-bottom));
        $.top-var.set-value(TBNumber.new(value => $graphics-context.viewport-top));
    }
}

=begin pod
=head1 EXPORTS

All graphics functions, commands, and utilities are exported.

=head1 USAGE

    use Graphics;
    
    # Initialize graphics
    init-graphics();
    
    # Set up coordinate system
    my $set-window = SetWindowCommand.new(
        x1 => TBNumber.new(value => 0),
        x2 => TBNumber.new(value => 10),
        y1 => TBNumber.new(value => 0),
        y2 => TBNumber.new(value => 10)
    );
    $set-window.execute();
    
    # Plot a point
    plot-point(5.0, 5.0);
    
    # Draw a line
    draw-line(0.0, 0.0, 10.0, 10.0);
    
    # Export graphics
    export-graphics("plot.svg", "svg");
    
    # Run graphics event loop
    graphics-event-loop();

=head2 True BASIC Graphics Commands Supported

- SET WINDOW: Define world coordinate system
- SET VIEWPORT: Define screen coordinate viewport
- PLOT: Plot points and lines
- PLOT LINES: Draw connected line segments
- PLOT AREA: Draw filled polygons
- BEAM ON/OFF: Control line drawing mode
- CLEAR: Clear graphics canvas
- ASK WINDOW/VIEWPORT/STATUS: Query graphics state

=head2 Graphics Export Formats

- SVG: Scalable Vector Graphics (requires Cairo module)
- PNG: Portable Network Graphics (requires Cairo module)

=end pod